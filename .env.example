# Copy this to .env and fill in your values. Never commit .env to git!

# From Discord Developer Portal > Your App > Bot > Token
DISCORD_TOKEN=your_bot_token_here

# From Discord Developer Portal > Your App > General Information > Application ID
DISCORD_CLIENT_ID=your_client_id_here

# Right-click your Discord server > Copy Server ID
DISCORD_GUILD_ID=1168893924329402420

# Right-click #raid-mobs > Copy Channel ID
TIMER_CHANNEL_ID=1496263398495621302

# Right-click your Historic Kills thread inside #raid-mobs > Copy Channel ID
HISTORIC_KILLS_THREAD_ID=your_historic_kills_thread_id_here

# Comma-delimited list of role names that can use /kill, /unkill, /board, /announce
# Must match exactly (capitalization, spaces). Add as many as you need.
ALLOWED_ROLE_NAMES=Pack Member,Officer,Guild Leader
