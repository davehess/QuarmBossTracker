# Copy this to .env and fill in your values
# Never commit .env to git!

# From Discord Developer Portal > Your App > Bot > Token
DISCORD_TOKEN=your_bot_token_here

# From Discord Developer Portal > Your App > General Information > Application ID
DISCORD_CLIENT_ID=your_client_id_here

# Right-click your Discord server > Copy Server ID (enable Developer Mode first)
DISCORD_GUILD_ID=1168893924329402420

# Right-click the #raid-mobs channel > Copy Channel ID
TIMER_CHANNEL_ID=1496263398495621302

# Right-click the "Historic Kills" thread inside #raid-mobs > Copy Channel ID
# The bot will archive kill embeds here when a boss respawns and delete
# the original message from #raid-mobs to keep the channel clean.
HISTORIC_KILLS_THREAD_ID=your_historic_kills_thread_id_here

# The exact name of the role that can use /kill, /unkill, and /board
# Must match exactly, including capitalization and spaces
ALLOWED_ROLE_NAME=Pack Member
