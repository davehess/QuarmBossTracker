# ── Discord App ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_GUILD_ID=1168893924329402420

# ── Timezone ───────────────────────────────────────────────────────────────────
# IANA timezone name. Defaults to America/New_York (Eastern, DST-aware).
# Examples: America/Chicago  America/Denver  America/Los_Angeles  UTC
DEFAULT_TIMEZONE=America/New_York

# ── Main channel ──────────────────────────────────────────────────────────────────
# #raid-mobs — summary card and "expansion → thread" placeholders live here
TIMER_CHANNEL_ID=1496263398495621302

# ── Expansion threads (create threads inside #raid-mobs, copy IDs) ────────────
# Right-click each thread → Copy Channel ID
CLASSIC_THREAD_ID=your_classic_thread_id
KUNARK_THREAD_ID=your_kunark_thread_id
VELIOUS_THREAD_ID=your_velious_thread_id
LUCLIN_THREAD_ID=your_luclin_thread_id
POP_THREAD_ID=your_pop_thread_id

# ── Historic Kills thread ──────────────────────────────────────────────────────
# Thread inside #raid-mobs where kill archives and midnight summaries go
HISTORIC_KILLS_THREAD_ID=your_historic_kills_thread_id

# ── Suggest / event request ──────────────────────────────────────────────────
# Channel (officer-only) where /suggest posts event requests for officers to claim.
SUGGEST_CHANNEL_ID=your_suggest_channel_id

# Forum channel where members create "event request" posts.
# The bot watches for new threads here and auto-replies with /suggest instructions.
# Hardcoded default: 1242116105326166057
FORUM_CHANNEL_ID=1242116105326166057

# ── Auto-Raid Invite (ARI) ────────────────────────────────────────────────────
# Default password used by /autoraidinvite (/ari) when no password argument is given.
# Officers can override per-set by passing a password explicitly.
ARI_DEFAULT_PASSWORD=

# ── Feedback thread ───────────────────────────────────────────────────────────────
# Thread where /feedback submissions are posted for officer review.
# Create a thread (officers-only or private) and paste its ID here.
FEEDBACK_THREAD_ID=your_feedback_thread_id

# ── QOL thread ────────────────────────────────────────────────────────────────────
# Thread where ⚑ PoP-anomaly flags from the Mimic PoP raid overlay land
# (guide-baseline vs observed-on-Quarm divergence reports).
# Falls back to FEEDBACK_THREAD_ID if unset.
QOL_THREAD_ID=your_qol_thread_id

# ── Parse log thread ───────────────────────────────────────────────────────────────
# Thread where every /parse submission is archived as a JSON embed.
# This is the source of truth for parse data — survives Railway volume wipes.
# Create a thread (e.g. "Parse Logs") and paste its ID here.
PARSES_LOG_THREAD_ID=your_parse_log_thread_id

# ── Autoparse testing thread ────────────────────────────────────────────────────────
# Thread where every agent upload posts a human-readable parse card as it arrives.
# Covers ALL encounters (boss and trash), not just boss matches.
# Use this to monitor data quality in real-time before going live.
# Create an officer-visible thread (e.g. "Autoparse Testing") and paste its ID here.
AUTOPARSE_TEST_THREAD_ID=

# ── Guild rules channels (for /ingestrules → guild_rules store, #94) ─────────────
# The three Discord channels that hold the guild rulebook. /ingestrules (officers
# only) reads each, parses messages into the `guild_rules` table (numbered rules
# get a rule_number + title; anything else lands as a raw-body row), and marks
# messages that were deleted inactive on re-run. Any that are unset are skipped
# and reported. View the result at wolfpack.quest/admin/rules.
RULES_CHANNEL_ID=your_rules_channel_id
RAID_RULES_CHANNEL_ID=your_raid_rules_channel_id
LOOT_RULES_CHANNEL_ID=your_loot_rules_channel_id

# ── RaidHelper auto-target import ───────────────────────────────────────────────
# When set, /raidnight scans this channel for the most recent RaidHelper event
# scheduled within ±18 hours of now and auto-adds its `Target -` and
# `Potential Additional Targets -` boss names to the raid session target list.
# Unmatched names (e.g. "Shei" → no exact boss match) are surfaced in the reply.
# Leave empty to disable.
RAIDHELPER_CHANNEL_ID=
# Optional: explicit RaidHelper bot ID. When unset we match by author username
# pattern (raid.?helper case-insensitive), which is fine for stock deployments.
RAIDHELPER_BOT_ID=

# ── Raid-Helper API (sign-up accuracy on /admin/signups) ───────────────────────
# Generated in Discord with: /apikey refresh && /apikey show
# When set alongside RH_SERVER_ID (or DISCORD_GUILD_ID), the bot syncs recent
# RH events + signups to rh_events/rh_signups every 30 min. Powers the
# /admin/signups reconciliation page (no-show / showed-unsignaled / etc).
RH_API_KEY=
RH_SERVER_ID=
# Optional base override; defaults to https://raid-helper.dev
RH_BASE_URL=

# ── Release announcement channel ────────────────────────────────────────────────
# When the bot boots and detects a newer agent version than the last one it
# announced (state.lastAnnouncedAgentVersion), it posts a brief release note
# here so end users know to update. Defaults to TIMER_CHANNEL_ID (#raid-mobs)
# when unset. Idempotent — once announced for a given version, it won't repost.
RELEASE_ANNOUNCE_CHANNEL_ID=

# Channel for Mimic release announcements (summary + beta/stable tag +
# installer link; one-time x.y backfill on first run). Hardcoded default:
# 1525569949551300729
MIMIC_RELEASE_CHANNEL_ID=

# Staging mode: when true, live Discord boards (expansion boards, summary cards, etc.)
# are NOT updated by agent uploads or kills. Data still writes to parses.json,
# state.json, the session accumulator, and AUTOPARSE_TEST_THREAD_ID.
# Flip to false (or remove) once you're satisfied with the data quality.
STAGING_MODE=false

# ── Onboarding thread ───────────────────────────────────────────────────────────────
# Thread where the public Quick Start instructions and the opt-out registry live.
# The registry message stores salted SHA-256 hashes only — no user IDs are kept.
# Use the ID you were given: 1498883334065885296
ONBOARDING_THREAD_ID=1498883334065885296

# ── Roster threads ───────────────────────────────────────────────────────────────────
# Two threads (inside any channel) where the character roster is stored.
# Run /rosterimport to populate them. On each redeploy the bot reloads from here.
# Only name, race, and class are stored — no DKP, ranks, or Discord handles.
ROSTER_ACTIVE_THREAD_ID=your_roster_active_thread_id
ROSTER_INACTIVE_THREAD_ID=your_roster_inactive_thread_id

# ── Boss output channel ───────────────────────────────────────────────────────────────
# Channel where bosses.json is posted after /addboss or /removeboss.
BOSS_OUTPUT_CHANNEL_ID=your_boss_output_channel_id

# ── Onboarding thread ───────────────────────────────────────────────────────────────
# Thread where the bot posts public Quick Start instructions and stores the
# opt-out registry (salted SHA-256 hashes only — no user IDs in plaintext).
# Create a thread (e.g. "Getting Started") and paste its ID here.
# Set to: 1498883334065885296
ONBOARDING_THREAD_ID=your_onboarding_thread_id

# ── Archive channel ───────────────────────────────────────────────────────────────────
# Channel where passed announce threads are summarized at midnight
ARCHIVE_CHANNEL_ID=1497636508981530804

# ── Roles ───────────────────────────────────────────────────────────────────────────
# General access — /kill, /unkill, /pvpkill, /updatetimer, /timers, etc.
ALLOWED_ROLE_NAMES=Pack Member,Officer,Guild Leader

# Officer access — /announce, cancel event button, /tick, /board, /cleanup, /restore, /addboss, /removeboss, /feedbacklist
# Defaults to ALLOWED_ROLE_NAMES if not set.
OFFICER_ROLE_NAMES=Officer,Guild Leader

# ── Fixed channel slot message IDs (hardcode these once, never change) ─────────
# These are the specific message IDs that will ALWAYS be edited in place.
# Get them by right-clicking the messages in #raid-mobs (Developer Mode must be on).
SUMMARY_MESSAGE_ID=1496610319534133248
SPAWNING_TOMORROW_MESSAGE_ID=1496610321438343228
DAILY_SUMMARY_MESSAGE_ID=1496610323732369579
THREAD_LINKS_MESSAGE_ID=your_thread_links_message_id

# ── Discord Event permissions ────────────────────────────────────────────────
# /announce creates Discord Scheduled Events. Add "Manage Events" permission to the bot
# in the OAuth2 URL Generator, or events will silently fail (announcement still works).

# ── Thread board message IDs (optional but recommended for redeploy safety) ───
# After running /board once, right-click the FIRST board panel in each thread
# and copy its message ID. Add all panel IDs comma-separated.
# Get panel count from bot startup logs or /board output.
# Format: CLASSIC_BOARD_IDS=id1,id2,id3
# These hardcoded IDs mean the bot will ALWAYS edit these messages, never re-post.
CLASSIC_BOARD_IDS=
KUNARK_BOARD_IDS=
VELIOUS_BOARD_IDS=
LUCLIN_BOARD_IDS=
POP_BOARD_IDS=

# ── Thread cooldown card message IDs (one per thread, top post) ──────────────────
# After /board, right-click the Active Cooldowns card at the top of each thread.
CLASSIC_COOLDOWN_ID=
KUNARK_COOLDOWN_ID=
VELIOUS_COOLDOWN_ID=
LUCLIN_COOLDOWN_ID=
POP_COOLDOWN_ID=

# ── Plane of Hate tracker thread ─────────────────────────────────────────────────
# Thread where /hateboard posts the persistent live + PVP tracker boards and floor maps.
# Set to: 1502031518090924224
HATE_THREAD_ID=1502031518090924224

# After running /hateboard once, right-click each board message → Copy ID and paste below.
# These IDs survive redeploys so the bot always edits the same messages.
LIVE_HATE_BOARD_ID=
PVP_HATE_BOARD_ID=

# ── Live server kill tracking ──────────────────────────────────────────────────────
# Channel where /livekill and /livehatekill post kill cards, soon alerts, and spawn notices.
LIVE_CHANNEL_ID=

# ── Trigger → Discord pipe ─────────────────────────────────────────────────────────
# Channel where the agent relays trigger fires (POST /api/agent/trigger) — e.g.
# boss rampage callouts, or any user-defined `discord` trigger action. Leave
# UNSET to disable the pipe entirely (the endpoint accepts + no-ops). Multiple
# raiders' agents fire the same trigger; the bot dedups by the trigger's key
# (10s) so the channel sees one line per event, with mass-mentions disabled.
TRIGGER_BROADCAST_CHANNEL_ID=

# ── Voice trigger pipe ─────────────────────────────────────────────────────────────
# When a trigger fires with `mode: 'voice'`, the bot joins one of these voice
# channels and speaks the message via Edge TTS (Microsoft's free read-aloud
# endpoint, no auth). Connect-on-demand, idle out after 5 min of silence.
# REQUIRES:
#   • Bot role must have CONNECT + SPEAK on the channel
#   • Container needs ffmpeg (the Dockerfile installs it via `apk add ffmpeg`)
#   • npm deps: @discordjs/voice, opusscript, libsodium-wrappers, msedge-tts
# Test before going live with: /voicetest
# Set to: 1186510068108243035
RAID_VOICE_CHANNEL_ID=
# Off-night event voice (e.g. impromptu farm runs). Same plumbing, distinct
# channel so the raid channel stays uninterrupted on off-nights. Targetable
# by `/voicetest channel:offnight`. Leave UNSET to skip.
# Set to: 1194335983903178783
OFFNIGHT_VOICE_CHANNEL_ID=

# ── PVP tracking ───────────────────────────────────────────────────────────────────
# Thread where /pvpkill posts kill cards and timers are tracked.
# Set to: 1499829617853206771
PVP_KILLS_THREAD_ID=

# Channel/thread for PVP alerts, quake alerts, and spawn notifications.
# If both are set, PVP_THREAD_ID takes priority.
# If neither is set, alerts post in the channel where the command was used.
PVP_CHANNEL_ID=
PVP_THREAD_ID=

# Role to ping for PVP alerts and spawn notifications (default: PVP)
PVP_ROLE=PVP

# PvP "quiet hours" — automated @PVP role pings (timer spawn alerts + live-kill /
# death broadcasts) are SUPPRESSED during this window so they don't wake the pack
# overnight. The informational message still posts; only the role ping is dropped.
# Manual rallies (/pvpalert, /pvpspawn) are NOT affected. Whole hours 0–23 in
# DEFAULT_TIMEZONE; defaults to 1am–8am. Set both equal to disable. Wraps midnight
# if start > end (e.g. 22 → 6).
PVP_QUIET_START=1
PVP_QUIET_END=8

# ── OpenDKP DKP tick integration ──────────────────────────────────────────────────
# Enables /tick command to post attendance directly to OpenDKP.
#
# How to find these values:
#   1. Open wolfpack.opendkp.com in Chrome, open DevTools → Network tab
#   2. Refresh the page and look for the first API call to execute-api.us-east-2.amazonaws.com
#      → that hostname is your OPENDKP_RAIDS_URL base (just the scheme+hostname)
#   3. Look at request headers — the "clientid" header value is OPENDKP_CLIENT_ID
#   4. Search the page source for "ClientId" or "userPoolWebClientId" to find OPENDKP_COGNITO_CLIENT_ID
#
# OPENDKP_RAIDS_URL: base URL for the raids API Gateway endpoint
# e.g. https://XXXXXXXX.execute-api.us-east-2.amazonaws.com
OPENDKP_RAIDS_URL=

# Read-only clientid header (base64 string, from request headers on the site)
OPENDKP_CLIENT_ID=

# Cognito App Client ID (from page source, looks like: 1a2b3c4d5e6f...)
OPENDKP_COGNITO_CLIENT_ID=

# Officer/admin OpenDKP login — used by the bot for write access.
# IMPORTANT: this is the USERNAME on the account (e.g. 'RaidBosses'), NOT the
# email address.  OpenDKP's Cognito user pool authenticates by username.
# (Legacy OPENDKP_EMAIL env var still works; just set the value to the username.)
OPENDKP_USERNAME=
OPENDKP_PASSWORD=

# DKP Pool ID for new raids (5 = SoL / Shadows of Luclin, current as of 2026-05)
OPENDKP_POOL_ID=5

# ── OpenDKP character API ─────────────────────────────────────────────────────────
# Base URL for the OpenDKP REST API used by /register (character creation).
# Default: https://api.opendkp.com — only change if your instance differs.
OPENDKP_API_URL=https://api.opendkp.com

# Client/guild slug in OpenDKP URLs (e.g. "wolfpack" → /clients/wolfpack/characters).
# Also used to build character profile URLs: https://{name}.opendkp.com/#/characters/{id}
OPENDKP_CLIENT_NAME=wolfpack

# Default bidding-window length (minutes) used by /loot when the officer
# doesn't pass an explicit bid_minutes. OpenDKP's web UI defaults to 3;
# adjust per guild convention.
LOOT_DEFAULT_BID_MINUTES=3

# ── Officer notification channel ──────────────────────────────────────────────────
# Channel where /register posts "new character created" notifications for officers.
OFFICER_CHAT_CHANNEL_ID=your_officer_chat_channel_id

# ── Google Sheets integration ─────────────────────────────────────────────────────────
# Service account credentials for reading/writing Google Sheets.
#
# Setup steps:
#   1. Go to console.cloud.google.com → create/select a project
#   2. Enable the Google Sheets API
#   3. IAM & Admin → Service Accounts → Create service account
#   4. Create a JSON key for it → download the file
#   5. Share each spreadsheet with the service account email (Editor access)
#   6. Paste the entire JSON key file contents as a single line below
#
# The service account email looks like: name@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_JSON=

# Spreadsheet IDs (the long string in the Google Sheets URL)
# Luclin key / Lucid Shards tracker
LUCLIN_KEYS_SHEET_ID=11gvjrooavHNm07aHW5KSPQ3xT6QN39W9FB6sAM2szf0

# PoP flagging tracker (set once that sheet exists)
POP_FLAGS_SHEET_ID=

# ── Supabase (RaidBosses project) ─────────────────────────────────────────────
# Required for: /wishlist, /mywishlist, /encounter, /dkp (family mode),
#               wolfpack-logsync agent ingest, loot wishlist matching.
# Project URL: https://zhtoekwakucbckvatfky.supabase.co
SUPABASE_URL=https://zhtoekwakucbckvatfky.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Guild identifier written to all Supabase rows (default: wolfpack)
SUPABASE_GUILD_ID=wolfpack

# ── Bid strategy privacy (REQUIRED for production) ───────────────────────────
# AES-256 key used to encrypt wishlist bid amounts in Supabase.
# Without this, bid amounts are stored in plaintext (dev-only, NOT suitable for production).
#
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Store this in 1Password / Railway secrets. Losing it means existing bids
# cannot be decrypted (members would need to re-enter their bid amounts).
WISHLIST_BID_KEY=

# ── wolfpack-logsync agent ────────────────────────────────────────────────────
# Bearer token the local logsync agent uses when posting encounter data.
# Must match the WOLFPACK_AGENT_TOKEN env var set in Railway/Docker.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WOLFPACK_AGENT_TOKEN=

# Agent hot-swap manifest refs (decoupled from bot deploys — the bot serves the
# agent index.js + its sha from these git refs so agents self-update with no
# redeploy). STABLE callers get AGENT_RELEASE_REF; a beta Mimic build asking
# GET /api/agent/latest-version?channel=beta gets AGENT_RELEASE_REF_BETA. Both
# optional; defaults track the branches. AGENT_RELEASE_REF_BETA is also live-
# overridable via the `agent_release_ref_beta` tuning key on /admin/overlays.
# AGENT_RELEASE_REF=main
# AGENT_RELEASE_REF_BETA=beta

# Graceful-shutdown drain window (ms) before the bot destroys the Discord client
# and exits on SIGTERM — Railway's zero-downtime handoff (#58). Default 10000.
# SHUTDOWN_DRAIN_MS=10000

# ── Egress / poll tuning knobs ────────────────────────────────────────────────
# Defaults are calibrated for Supabase Free tier (5 GB/mo egress). Bump up
# when on Pro/Team or a self-hosted Postgres where egress is abundant; cap
# down on a tight tier. All optional — falling back to defaults if unset.

# Web-feedback poll cadence in milliseconds. The web's /feedback submit
# handler already relays to the bot synchronously; this poll is a backstop
# for the rare race where that fires-and-fails. Default 300000 (5 min).
# FEEDBACK_POLL_MS=300000

# Days of encounter_threat_snapshots retained by the nightly retention
# sweep. Per-fight tank-pull telemetry — useful during the fight + /parses
# post-mortem, dead weight after. Set to 0 to disable the sweep entirely
# (e.g. on a tier with abundant storage). Default 60.
# THREAT_SNAPSHOT_RETENTION_DAYS=60

# Max rows fetched per buff-queue poll. A 3h window with 30 active raiders
# peaks at ~300-400 distinct relevant rows. Bump for completeness, drop
# for tighter egress. Default 400.
# BUFF_QUEUE_POLL_LIMIT=400

# Bot HTTP base URL — required by the web's /admin/links register-in-OpenDKP
# button (server action POSTs to ${BOT_BASE_URL}/api/admin/opendkp-register
# with the agent bearer). Set on Vercel to the Railway bot's public URL.
# BOT_BASE_URL=https://your-bot.up.railway.app
