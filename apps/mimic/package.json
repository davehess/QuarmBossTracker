{
  "name": "wolfpack-mimic",
  "version": "1.0.42",
  "private": true,
  "description": "Wolf Pack Mimic — Electron desktop client. Wraps the wolfpack-logsync agent in a native shell with a real window + always-on-top overlay. Bundles its own Node runtime, so no separate Node install.",
  "author": "Wolf Pack EQ",
  "repository": {
    "type": "git",
    "url": "https://github.com/davehess/QuarmBossTracker.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --publish never",
    "dist:dir": "electron-builder --dir",
    "postinstall": "node scripts/stage-agent.js"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "quest.wolfpack.mimic",
    "productName": "Wolf Pack Mimic",
    "directories": { "output": "dist", "buildResources": "build" },
    "generateUpdatesFilesForAllChannels": true,
    "files": [
      "**/*",
      "!**/*.md",
      "!staged-agent/**",
      "!scripts/**",
      "!dist/**",
      "!.gitignore"
    ],
    "extraResources": [
      { "from": "staged-agent", "to": "agent" }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "davehess",
        "repo": "QuarmBossTracker"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip",  "arch": ["x64"] }
      ],
      "artifactName": "Wolf-Pack-Mimic-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": false,
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "include": "build/installer.nsh",
      "artifactName": "Wolf-Pack-Mimic-Setup-${version}.${ext}"
    }
  }
}
