# Production URL — used for OG / canonical tags and the Discord OAuth callback.
# Vercel auto-sets VERCEL_URL on each deploy, but we want a stable value so we
# pin this here. Override in Preview environments if needed.
NEXT_PUBLIC_SITE_URL=https://wolfpack.quest

# Same Supabase project the Discord bot already uses. Anon key is safe to ship
# to the browser — RLS policies on the Supabase side control what's readable.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only: needed for the OAuth callback to upsert wolfpack_members rows
# (bypasses RLS so a freshly-signed-in user's row can be written before any
# session-scoped policies apply). Find under Supabase Dashboard → Settings →
# API → service_role key. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Discord guild ID for the membership check on sign-in. The callback route
# calls Discord's API to confirm the signed-in user is in this guild before
# letting them through. Default matches the Wolf Pack EQ server.
DISCORD_GUILD_ID=1168893924329402420

# Discord OAuth client credentials are NOT needed here — they're configured
# directly in the Supabase Auth dashboard (Authentication → Sign In / Providers
# → Discord). These vars are documented for the case where we eventually
# move off Supabase Auth onto NextAuth.
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
