# Production URL — used for OG / canonical tags and the Discord OAuth callback.
# Vercel auto-sets VERCEL_URL on each deploy, but we want a stable value so we
# pin this here. Override in Preview environments if needed.
NEXT_PUBLIC_SITE_URL=https://wolfpack.quest

# Same Supabase project the Discord bot already uses. Anon key is safe to ship
# to the browser — RLS policies on the Supabase side control what's readable.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only: needed for admin queries (e.g. seeding eqemu_spells from a CSV
# upload). Leave unset in production unless you have a route that genuinely
# needs to bypass RLS.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Discord OAuth (configured in the Supabase Auth dashboard — these names are
# what NextAuth would expect if we move off Supabase Auth later).
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
